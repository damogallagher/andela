{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "PrivateBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "AccessControl": "Private"
      }
    },
    "ReadonlyPolicy": {
      "Type": "AWS::IAM::Policy",
      "Properties": {
        "PolicyName": "readonly-reports",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "s3:GetObject"
              ],
              "Resource": [
                "arn:aws:s3:::private-reports/*"
              ]
            }
          ]
        }
      }
    }
  }
}
