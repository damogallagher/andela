{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "PublicReportsBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "AccessControl": "PublicRead"
      }
    },
    "OrdersDatabase": {
      "Type": "AWS::RDS::DBInstance",
      "Properties": {
        "Engine": "postgres",
        "DBInstanceClass": "db.t3.micro",
        "StorageEncrypted": false
      }
    }
  }
}

