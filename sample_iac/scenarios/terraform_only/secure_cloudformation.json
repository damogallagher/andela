{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "PrivateReportsBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "AccessControl": "Private"
      }
    },
    "SecureDatabase": {
      "Type": "AWS::RDS::DBInstance",
      "Properties": {
        "Engine": "postgres",
        "DBInstanceClass": "db.t3.micro",
        "StorageEncrypted": true
      }
    }
  }
}

